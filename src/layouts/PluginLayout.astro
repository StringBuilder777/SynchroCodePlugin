---
/**
 * PluginLayout — Layout de producción para el webview de VS Code.
 * Sin frame decorativo. VS Code provee la sidebar nativa.
 * Navegación via postMessage ↔ extension.ts
 */
interface Props {
  title?: string;
  theme?: 'dark' | 'light';
}
const { title = 'SynchroCode', theme = 'dark' } = Astro.props;
import '../styles/global.css';
---
<!doctype html>
<html lang="es" class={theme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Inicializar VS Code API UNA sola vez + aplicar tema guardado antes del primer render -->
    <script is:inline>
      (function () {
        // VS Code sólo permite acquireVsCodeApi() una vez por página
        if (typeof acquireVsCodeApi !== 'undefined' && !window.__vscode) {
          window.__vscode = acquireVsCodeApi();
        }
        // Restaurar tema guardado sin flash
        var saved = localStorage.getItem('synchrocode-theme');
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.className = saved;
        }
      })();
    </script>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0;
        height: 100%; width: 100%;
        font-family: 'Inter', system-ui, sans-serif;
        overflow: hidden;
      }
      #app { height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      .custom-scrollbar::-webkit-scrollbar { width: 4px; }
      .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
      .custom-scrollbar::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 2px; }

      /* Theme toggle button */
      #synchro-theme-btn {
        position: fixed;
        bottom: 10px;
        left: 10px;
        z-index: 200;
        width: 26px;
        height: 26px;
        border-radius: 50%;
        border: 1px solid transparent;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0.35;
        transition: opacity 0.15s;
        padding: 0;
      }
      #synchro-theme-btn:hover { opacity: 1; }
      html.dark  #synchro-theme-btn { color: #a1a1aa; border-color: #3f3f46; }
      html.light #synchro-theme-btn { color: #64748b; border-color: #cbd5e1; }
    </style>
  </head>
  <body>
    <div id="app">
      <slot />
    </div>

    <!-- Theme toggle -->
    <button id="synchro-theme-btn" title="Cambiar tema (claro/oscuro)">
      <span class="material-symbols-outlined" style="font-size:14px;line-height:1">dark_mode</span>
    </button>

    <!-- VS Code bridge + Theme logic -->
    <script>
      (function () {
        // Usar la instancia ya inicializada en el script inline de <head>
        const vscode = window.__vscode || null;

        /** Navega a otra pantalla */
        window.__navigate = function (screen) {
          if (vscode) {
            vscode.postMessage({ command: 'navigate', screen });
          } else {
            window.location.href = '/plugin/' + screen;
          }
        };

        /** Intercepta <a href="/..."> internos */
        document.addEventListener('click', function (e) {
          const a = e.target.closest('a[href]');
          if (!a) return;
          const href = a.getAttribute('href');
          if (href && href.startsWith('/') && !href.startsWith('//')) {
            e.preventDefault();
            const screen = href.replace(/^\/plugin\//, '').replace(/^\//, '');
            if (screen) window.__navigate(screen);
          }
        });

        // ── Theme ────────────────────────────────────────────────
        function applyTheme(t) {
          document.documentElement.classList.toggle('dark',  t === 'dark');
          document.documentElement.classList.toggle('light', t === 'light');
          var icon = document.querySelector('#synchro-theme-btn .material-symbols-outlined');
          if (icon) icon.textContent = t === 'light' ? 'dark_mode' : 'light_mode';
        }

        // Sync icon with current class (class was set by inline script or injected HTML)
        applyTheme(document.documentElement.classList.contains('light') ? 'light' : 'dark');

        // VS Code → webview: theme changed (e.g. user changes VS Code color theme)
        window.addEventListener('message', function (event) {
          var msg = event.data;
          if (msg && msg.command === 'themeChanged') {
            localStorage.setItem('synchrocode-theme', msg.theme);
            applyTheme(msg.theme);
          }
        });

        // Toggle button click
        document.getElementById('synchro-theme-btn')
          ?.addEventListener('click', function () {
            var isLight = document.documentElement.classList.contains('light');
            var next = isLight ? 'dark' : 'light';
            localStorage.setItem('synchrocode-theme', next);
            applyTheme(next);
            if (vscode) vscode.postMessage({ command: 'themeToggled', theme: next });
          });
      })();
    </script>
  </body>
</html>
