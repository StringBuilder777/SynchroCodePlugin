---
import PluginLayout from '../../layouts/PluginLayout.astro';
---
<PluginLayout title="SynchroCode — Colaborar" theme="dark">
  <div class="flex flex-col h-full bg-[var(--plugin-bg)]">

    <!-- Header -->
    <header class="flex items-center justify-between px-4 py-3 border-b border-zinc-800 bg-zinc-950 shrink-0">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 shrink-0 rounded-full bg-[#2e75b8]/10 border border-[#2e75b8]/20 flex items-center justify-center text-xs font-bold text-[#2e75b8]">AR</div>
        <span class="text-[13px] font-semibold text-slate-200">Alex Rivera</span>
      </div>
      <div class="flex items-center gap-1">
        <button onclick="window.__navigate('notificaciones')" class="relative p-1.5 hover:bg-zinc-800 rounded transition-colors">
          <span class="material-symbols-outlined text-[20px] text-zinc-400">notifications</span>
          <span class="absolute top-1.5 right-1.5 flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
          </span>
        </button>
        <button class="p-1.5 hover:bg-zinc-800 rounded transition-colors text-zinc-400">
          <span class="material-symbols-outlined text-[20px]">more_vert</span>
        </button>
      </div>
    </header>


    <!-- ═══════════════════════════════════════════════════════════
         ESTADO 0 — Sin sesión activa (vista inicial)
    ════════════════════════════════════════════════════════════════ -->
    <div id="view-no-session" class="flex-1 overflow-y-auto custom-scrollbar px-3 py-6 flex flex-col gap-5">

      <!-- Ícono central -->
      <div class="flex flex-col items-center py-4 gap-2">
        <div class="w-14 h-14 rounded-2xl bg-[#2e75b8]/10 border border-[#2e75b8]/20 flex items-center justify-center">
          <span class="material-symbols-outlined text-[32px] text-[#2e75b8]">screen_share</span>
        </div>
        <p class="text-[13px] font-semibold text-slate-200 mt-1">Sesión Colaborativa</p>
        <p class="text-[11px] text-zinc-500 text-center leading-relaxed max-w-[220px]">
          Comparte tu archivo en tiempo real o únete a la sesión de otro programador.
        </p>
      </div>

      <!-- Opción A: Iniciar sesión (Editor) -->
      <button id="startSessionBtn"
        class="w-full py-3 bg-[#2e75b8] hover:bg-[#2567a4] text-white rounded-md font-semibold text-[12px] flex items-center justify-center gap-2 transition-colors">
        <span class="material-symbols-outlined text-[16px]">play_circle</span>
        Iniciar sesión colaborativa
      </button>

      <!-- Separador -->
      <div class="flex items-center gap-3">
        <div class="flex-1 border-t border-zinc-800"></div>
        <span class="text-[10px] text-zinc-600 shrink-0">o únete con un código</span>
        <div class="flex-1 border-t border-zinc-800"></div>
      </div>

      <!-- Opción B: Unirse con código (Observador) -->
      <div class="space-y-2">
        <div class="flex gap-2">
          <input id="codeInput" type="text" maxlength="9" placeholder="SC4F-9X2K"
            class="flex-1 bg-zinc-900 border border-zinc-700 rounded px-3 py-2 text-[13px] font-mono tracking-[0.15em] text-zinc-200 placeholder-zinc-600 focus:outline-none focus:border-[#2e75b8] uppercase transition-colors" />
          <button id="joinSessionBtn"
            class="px-3 py-2 bg-zinc-800 hover:bg-zinc-700 text-zinc-200 rounded text-[12px] font-medium border border-zinc-700 transition-colors flex items-center gap-1.5 shrink-0">
            <span class="material-symbols-outlined text-[14px]">login</span>
            Unirse
          </button>
        </div>

        <!-- Error: código inválido o expirado (E1) -->
        <div id="join-error" class="hidden items-center gap-1.5 bg-red-500/10 border border-red-500/30 rounded px-3 py-2">
          <span class="material-symbols-outlined text-[14px] text-red-400 shrink-0">error</span>
          <p class="text-[11px] text-red-400">Código inválido o la sesión ya finalizó.</p>
        </div>

        <!-- Error: sin acceso al proyecto (E2 — 403) -->
        <div id="join-error-403" class="hidden items-center gap-1.5 bg-red-500/10 border border-red-500/30 rounded px-3 py-2">
          <span class="material-symbols-outlined text-[14px] text-red-400 shrink-0">block</span>
          <p class="text-[11px] text-red-400">No tienes acceso a este proyecto.</p>
        </div>
      </div>

      <p class="text-[10px] text-zinc-600 text-center">Los códigos expiran en 30 minutos</p>
    </div>


    <!-- ═══════════════════════════════════════════════════════════
         ESTADO 1 — Sesión activa
    ════════════════════════════════════════════════════════════════ -->
    <div id="view-session" class="hidden flex-col flex-1 overflow-hidden">

      <!-- ── Banners de estado global ──────────────────────────── -->

      <!-- Banner: A perdió conexión, transmisión pausada — visible para A (E3 de CU-031a) -->
      <div id="banner-self-disconnected"
        class="hidden mx-3 mt-2 shrink-0 items-center gap-2 bg-yellow-500/10 border border-yellow-500/30 rounded px-3 py-2">
        <span class="material-symbols-outlined text-[14px] text-yellow-400" style="animation: spin 2s linear infinite">sync</span>
        <p class="text-[11px] text-yellow-400">Sin conexión · Reconectando automáticamente...</p>
      </div>

      <!-- Banner: El editor (A) perdió conexión — visible para B (E3 de CU-031a) -->
      <div id="banner-editor-disconnected"
        class="hidden mx-3 mt-2 shrink-0 items-center gap-2 bg-orange-500/10 border border-orange-500/30 rounded px-3 py-2">
        <span class="material-symbols-outlined text-[14px] text-orange-400 shrink-0">wifi_off</span>
        <p class="text-[11px] text-orange-400">El editor perdió conexión · La sesión se pausó · Reintentando...</p>
      </div>

      <!-- Banner: Lock disponible — A se desconectó con lock, B puede tomarlo (E2 de CU-031b) -->
      <div id="banner-lock-available"
        class="hidden mx-3 mt-2 shrink-0 items-center justify-between bg-emerald-500/10 border border-emerald-500/30 rounded px-3 py-2">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[14px] text-emerald-400 shrink-0">lock_open</span>
          <p class="text-[11px] text-emerald-400">El control está disponible</p>
        </div>
        <button id="takeLockBtn"
          class="text-[10px] font-semibold text-emerald-400 bg-emerald-500/20 border border-emerald-500/40 px-2 py-1 rounded hover:bg-emerald-500/30 transition-colors shrink-0 ml-3">
          Tomar control
        </button>
      </div>

      <!-- ── Toggle Editor / Observador ───────────────────────── -->
      <div class="flex bg-zinc-900/50 p-1 mx-3 mt-3 mb-0 rounded-md border border-zinc-800 shrink-0">
        <button id="btn-editor"
          class="role-btn flex-1 py-1.5 flex items-center justify-center gap-1.5 bg-zinc-800 rounded text-[11px] font-medium text-[#2e75b8] shadow-sm transition-colors">
          <span class="material-symbols-outlined text-[14px]">edit</span>Editor (A)
        </button>
        <button id="btn-observer"
          class="role-btn flex-1 py-1.5 flex items-center justify-center gap-1.5 text-[11px] font-medium text-zinc-500 hover:text-zinc-300 transition-colors">
          <span class="material-symbols-outlined text-[14px]">visibility</span>Observador (B)
        </button>
      </div>


      <!-- ──────────────────────────────────────────────────────────
           VISTA EDITOR (A)
      ─────────────────────────────────────────────────────────────── -->
      <div id="view-editor" class="flex-1 overflow-y-auto custom-scrollbar px-3 py-3 space-y-4">

        <!-- ✱ Banner: B solicita el control de edición (CU-031b paso 3-4) -->
        <div id="lock-request-banner"
          class="hidden bg-amber-500/10 border border-amber-500/40 rounded-lg p-3 space-y-2.5">
          <div class="flex items-start gap-2.5">
            <span class="material-symbols-outlined text-[18px] text-amber-400 shrink-0 mt-0.5">hand_gesture</span>
            <div>
              <p class="text-[12px] font-semibold text-amber-300">Luisa García solicita el control de edición</p>
              <p class="text-[10px] text-amber-400/70 mt-0.5">Solo un programador puede editar a la vez</p>
            </div>
          </div>
          <div class="flex gap-2">
            <button id="grantLockBtn"
              class="flex-1 py-1.5 bg-emerald-500/20 text-emerald-400 border border-emerald-500/40 rounded text-[11px] font-semibold hover:bg-emerald-500/30 transition-colors flex items-center justify-center gap-1">
              <span class="material-symbols-outlined text-[13px]">check</span>Ceder control
            </button>
            <button id="denyLockBtn"
              class="flex-1 py-1.5 bg-red-500/10 text-red-400 border border-red-500/30 rounded text-[11px] font-semibold hover:bg-red-500/20 transition-colors flex items-center justify-center gap-1">
              <span class="material-symbols-outlined text-[13px]">close</span>Rechazar
            </button>
          </div>
        </div>

        <!-- Estado de la sesión -->
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span id="editor-status-dot" class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
            <span id="editor-status-text" class="text-[12px] font-medium text-green-400">Sesión activa · Transmitiendo</span>
          </div>
          <span class="text-[10px] font-mono text-green-400 bg-green-900/30 px-1.5 py-0.5 rounded border border-green-900/40">middleware.ts</span>
        </div>

        <!-- Código que A está transmitiendo -->
        <div class="bg-zinc-900 border border-zinc-800 rounded-lg overflow-hidden">
          <div class="flex items-center justify-between px-3 py-2 border-b border-zinc-800 bg-zinc-950">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-[14px] text-[#2e75b8]">code</span>
              <span class="text-[11px] font-mono text-zinc-300">middleware.ts</span>
            </div>
            <div class="flex items-center gap-1.5 text-[10px] text-green-400">
              <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>En vivo
            </div>
          </div>
          <pre class="p-3 text-[11px] font-mono text-zinc-300 overflow-x-auto leading-relaxed"><code><span class="text-purple-400">export</span> <span class="text-blue-400">const</span> <span class="text-yellow-300">authMiddleware</span> = <span class="text-zinc-400">(</span>
  <span class="text-orange-300">req</span><span class="text-zinc-400">:</span> <span class="text-green-300">Request</span><span class="text-zinc-400">,</span>
  <span class="text-orange-300">res</span><span class="text-zinc-400">:</span> <span class="text-green-300">Response</span><span class="text-zinc-400">,</span>
  <span class="text-orange-300">next</span><span class="text-zinc-400">:</span> <span class="text-green-300">NextFunction</span>
<span class="text-zinc-400">) =&gt; {</span>
  <span class="text-purple-400">const</span> <span class="text-blue-300">token</span> = req<span class="text-zinc-400">.</span>headers<span class="text-zinc-400">.</span>authorization
    <span class="text-zinc-400">?.</span><span class="text-yellow-300">split</span><span class="text-zinc-400">(</span><span class="text-green-400">' '</span><span class="text-zinc-400">)[</span><span class="text-orange-400">1</span><span class="text-zinc-400">];</span>
  <span class="text-purple-400">if</span> <span class="text-zinc-400">(!</span>token<span class="text-zinc-400">)</span> <span class="text-purple-400">return</span> res
    <span class="text-zinc-400">.</span><span class="text-yellow-300">status</span><span class="text-zinc-400">(</span><span class="text-orange-400">401</span><span class="text-zinc-400">)</span>
    <span class="text-zinc-400">.</span><span class="text-yellow-300">json</span><span class="text-zinc-400">({</span> <span class="text-blue-300">error</span><span class="text-zinc-400">:</span> <span class="text-green-400">'Unauthorized'</span> <span class="text-zinc-400">});</span>
  <span class="text-zinc-500">// ...</span><span class="animate-pulse text-zinc-400">|</span>
<span class="text-zinc-400">};</span></code></pre>
        </div>

        <!-- Código de invitación -->
        <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-3">
          <h3 class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider mb-2">Código de Invitación</h3>
          <div class="flex items-stretch gap-2">
            <div class="flex-1 bg-zinc-800/50 border border-zinc-700 rounded flex items-center justify-center py-2">
              <span class="text-base font-mono font-semibold tracking-[0.2em] text-zinc-100">SC4F-9X2K</span>
            </div>
            <button id="copyBtn" class="px-3 bg-[#2e75b8]/20 text-[#2e75b8] border border-[#2e75b8]/40 rounded hover:bg-[#2e75b8]/30 transition-colors" title="Copiar código">
              <span class="material-symbols-outlined text-[18px]">content_copy</span>
            </button>
          </div>
          <p class="text-[10px] text-center text-zinc-500 mt-2 italic">Comparte este código · Expira en 30 min</p>
        </div>

        <!-- Participantes -->
        <div>
          <h3 class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider mb-2">Participantes (2)</h3>
          <div class="space-y-2">
            <div class="flex items-center justify-between bg-zinc-900 border border-zinc-800 rounded p-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-[#2e75b8]/20 flex items-center justify-center text-[#2e75b8] text-xs font-bold">AR</div>
                <div>
                  <p class="text-[12px] font-semibold text-zinc-200">Alex Rivera</p>
                  <p class="text-[10px] text-zinc-500">Tú</p>
                </div>
              </div>
              <div id="badge-a"
                class="flex items-center gap-1 bg-green-900/20 text-green-400 px-2 py-1 rounded text-[10px] font-medium border border-green-900/40">
                <span class="material-symbols-outlined text-[12px]">edit</span>Editando
              </div>
            </div>
            <div class="flex items-center justify-between bg-zinc-900 border border-zinc-800 rounded p-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-emerald-900/30 flex items-center justify-center text-emerald-400 text-xs font-bold">LG</div>
                <div>
                  <p class="text-[12px] font-semibold text-zinc-200">Luisa García</p>
                  <p class="text-[10px] text-zinc-500">Observando</p>
                </div>
              </div>
              <span id="badge-b" class="text-[10px] text-zinc-500 bg-zinc-800 px-2 py-1 rounded border border-zinc-700">Solo lectura</span>
            </div>
          </div>
        </div>

        <!-- Botón de simulación (demo) -->
        <button id="simLockRequestBtn"
          class="w-full py-1.5 border border-dashed border-zinc-700 text-zinc-600 rounded text-[10px] hover:border-zinc-500 hover:text-zinc-400 transition-colors flex items-center justify-center gap-1">
          <span class="material-symbols-outlined text-[12px]">science</span>
          Demo: simular solicitud de control de B
        </button>
      </div>


      <!-- ──────────────────────────────────────────────────────────
           VISTA OBSERVADOR (B)
      ─────────────────────────────────────────────────────────────── -->
      <div id="view-observer" class="hidden flex-1 overflow-y-auto custom-scrollbar px-3 py-3 space-y-4">

        <!-- Estado observador -->
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
            <span class="text-[12px] font-medium text-blue-400">Observando · Alex Rivera edita</span>
          </div>
          <span class="text-[10px] font-mono text-blue-400 bg-blue-900/20 px-1.5 py-0.5 rounded border border-blue-900/40">middleware.ts</span>
        </div>

        <!-- Código en modo solo lectura (cursor de A) -->
        <div class="bg-zinc-900 border border-zinc-800 rounded-lg overflow-hidden">
          <div class="flex items-center justify-between px-3 py-2 border-b border-zinc-800 bg-zinc-950">
            <div class="flex items-center gap-2">
              <span class="material-symbols-outlined text-[14px] text-zinc-500">lock</span>
              <span class="text-[11px] font-mono text-zinc-400">middleware.ts</span>
              <span class="text-[9px] text-zinc-600 bg-zinc-800 px-1.5 py-0.5 rounded">Solo lectura</span>
            </div>
            <div class="flex items-center gap-1.5 text-[10px] text-blue-400">
              <span class="w-1.5 h-1.5 bg-blue-500 rounded-full animate-pulse"></span>Alex escribe
            </div>
          </div>
          <pre class="p-3 text-[11px] font-mono text-zinc-400 overflow-x-auto leading-relaxed select-none"><code><span class="text-purple-400">export</span> <span class="text-blue-400">const</span> <span class="text-yellow-300">authMiddleware</span> = <span class="text-zinc-400">(</span>
  <span class="text-orange-300">req</span><span class="text-zinc-400">:</span> <span class="text-green-300">Request</span><span class="text-zinc-400">,</span>
  <span class="text-orange-300">res</span><span class="text-zinc-400">:</span> <span class="text-green-300">Response</span><span class="text-zinc-400">,</span>
  <span class="text-orange-300">next</span><span class="text-zinc-400">:</span> <span class="text-green-300">NextFunction</span>
<span class="text-zinc-400">) =&gt; {</span>
  <span class="text-purple-400">const</span> <span class="text-blue-300">token</span> = req<span class="text-zinc-400">.</span>headers<span class="text-zinc-400">.</span>authorization
    <span class="text-zinc-400">?.</span><span class="text-yellow-300">split</span><span class="text-zinc-400">(</span><span class="text-green-400">' '</span><span class="text-zinc-400">)[</span><span class="text-orange-400">1</span><span class="text-zinc-400">];</span>
  <span class="bg-blue-500/30 px-0.5 rounded">  <span class="text-purple-400">try</span> <span class="text-zinc-400">{</span></span><span class="animate-pulse text-blue-400">|</span>
<span class="text-zinc-400">};</span></code></pre>
          <div class="px-3 py-1.5 border-t border-zinc-800 flex items-center gap-1.5 bg-zinc-950/50">
            <div class="w-2 h-2 rounded-full bg-blue-500 shrink-0"></div>
            <span class="text-[10px] text-zinc-500">Cursor de Alex Rivera — línea 9, col 3</span>
          </div>
        </div>

        <!-- ✱ Lock state: watching — botón solicitar control -->
        <div id="lock-state-watching">
          <button id="requestLockBtn"
            class="w-full py-2.5 border border-[#2e75b8]/40 text-[#2e75b8] rounded-md font-medium text-[12px] flex items-center justify-center gap-2 hover:bg-[#2e75b8]/10 transition-colors">
            <span class="material-symbols-outlined text-[16px]">edit_note</span>
            Solicitar control de edición
          </button>
        </div>

        <!-- ✱ Lock state: pending — solicitud enviada, esperando a A (CU-031b paso 2) -->
        <div id="lock-state-pending" class="hidden bg-zinc-900 border border-zinc-800 rounded-lg p-4 text-center space-y-3">
          <div class="flex items-center justify-center">
            <div class="w-8 h-8 border-2 border-[#2e75b8] border-t-transparent rounded-full animate-spin"></div>
          </div>
          <div>
            <p class="text-[12px] font-medium text-zinc-200">Solicitud enviada a Alex Rivera</p>
            <p class="text-[10px] text-zinc-500 mt-1">Esperando respuesta...</p>
          </div>
          <button id="cancelLockBtn"
            class="text-[11px] text-zinc-500 hover:text-zinc-300 border border-zinc-700 hover:border-zinc-500 rounded px-3 py-1.5 transition-colors">
            Cancelar solicitud
          </button>
        </div>

        <!-- ✱ Lock state: rejected — A rechazó la solicitud (E1 de CU-031b) -->
        <div id="lock-state-rejected" class="hidden bg-red-500/5 border border-red-500/20 rounded-lg p-4 text-center space-y-3">
          <span class="material-symbols-outlined text-[28px] text-red-400 block">do_not_disturb</span>
          <div>
            <p class="text-[12px] font-medium text-zinc-300">El editor rechazó tu solicitud</p>
            <p class="text-[10px] text-zinc-500 mt-1">Puedes intentarlo de nuevo más tarde.</p>
          </div>
          <button id="retryLockBtn"
            class="text-[11px] text-[#2e75b8] border border-[#2e75b8]/40 rounded px-3 py-1.5 hover:bg-[#2e75b8]/10 transition-colors">
            Intentar de nuevo
          </button>
        </div>

        <!-- Participantes en modo observador -->
        <div>
          <h3 class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider mb-2">Participantes (2)</h3>
          <div class="space-y-2">
            <div class="flex items-center justify-between bg-zinc-900 border border-zinc-800 rounded p-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-[#2e75b8]/20 flex items-center justify-center text-[#2e75b8] text-xs font-bold">AR</div>
                <div>
                  <p class="text-[12px] font-semibold text-zinc-200">Alex Rivera</p>
                  <p class="text-[10px] text-zinc-500">Tú</p>
                </div>
              </div>
              <span class="text-[10px] text-blue-400 bg-blue-900/20 px-2 py-1 rounded border border-blue-900/40 flex items-center gap-1">
                <span class="material-symbols-outlined text-[12px]">visibility</span>Observando
              </span>
            </div>
            <div class="flex items-center justify-between bg-zinc-900 border border-zinc-800 rounded p-3">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-full bg-zinc-700 flex items-center justify-center text-zinc-200 text-xs font-bold">CM</div>
                <div>
                  <p class="text-[12px] font-semibold text-zinc-200">Carlos Mendoza</p>
                  <p class="text-[10px] text-zinc-500">Propietario</p>
                </div>
              </div>
              <div class="flex items-center gap-1 bg-green-900/20 text-green-400 px-2 py-1 rounded text-[10px] font-medium border border-green-900/40">
                <span class="material-symbols-outlined text-[12px]">edit</span>Editando
              </div>
            </div>
          </div>
        </div>

        <!-- Botón de simulación (demo) -->
        <button id="simDisconnectBtn"
          class="w-full py-1.5 border border-dashed border-zinc-700 text-zinc-600 rounded text-[10px] hover:border-zinc-500 hover:text-zinc-400 transition-colors flex items-center justify-center gap-1">
          <span class="material-symbols-outlined text-[12px]">science</span>
          Demo: simular editor desconectado (heartbeat timeout)
        </button>
      </div>
    </div>

    <!-- Footer -->
    <footer class="p-2 border-t border-zinc-800 bg-zinc-950 flex items-center justify-around shrink-0">
      <button onclick="window.__navigate('dashboard')" class="flex flex-col items-center gap-0.5 px-2 py-1 text-zinc-500 hover:text-zinc-300">
        <span class="material-symbols-outlined text-[20px]">grid_view</span>
        <span class="text-[9px] font-medium">Dashboard</span>
      </button>
      <button onclick="window.__navigate('tareas')" class="flex flex-col items-center gap-0.5 px-2 py-1 text-zinc-500 hover:text-zinc-300">
        <span class="material-symbols-outlined text-[20px]">list_alt</span>
        <span class="text-[9px] font-medium">Tareas</span>
      </button>
      <button onclick="window.__navigate('chat')" class="flex flex-col items-center gap-0.5 px-2 py-1 text-zinc-500 hover:text-zinc-300">
        <span class="material-symbols-outlined text-[20px]">forum</span>
        <span class="text-[9px] font-medium">Chat</span>
      </button>
      <button onclick="window.__navigate('colaboracion')" class="flex flex-col items-center gap-0.5 px-2 py-1 text-[#2e75b8]">
        <span class="material-symbols-outlined text-[20px]">screen_share</span>
        <span class="text-[9px] font-medium">Colab</span>
      </button>
    </footer>
  </div>

  <style>
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>

  <script>
    const vscode = window.__vscode || null;

    // ── Helpers ──────────────────────────────────────────────────
    function showFlex(el) {
      el?.classList.remove('hidden');
      el?.classList.add('flex');
    }
    function showBlock(el) {
      el?.classList.remove('hidden');
    }
    function hideEl(el) {
      el?.classList.remove('flex');
      el?.classList.add('hidden');
    }

    // ── Referencias ──────────────────────────────────────────────
    const viewNoSession            = document.getElementById('view-no-session');
    const viewSession              = document.getElementById('view-session');
    const btnEditor                = document.getElementById('btn-editor');
    const btnObserver              = document.getElementById('btn-observer');
    const viewEditor               = document.getElementById('view-editor');
    const viewObserver             = document.getElementById('view-observer');
    const endIcon                  = document.getElementById('endIcon');
    const endLabel                 = document.getElementById('endLabel');
    const bannerSelfDisc           = document.getElementById('banner-self-disconnected');
    const bannerEditorDisc         = document.getElementById('banner-editor-disconnected');
    const bannerLockAvailable      = document.getElementById('banner-lock-available');
    const lockRequestBanner        = document.getElementById('lock-request-banner');
    const lockStateWatching        = document.getElementById('lock-state-watching');
    const lockStatePending         = document.getElementById('lock-state-pending');
    const lockStateRejected        = document.getElementById('lock-state-rejected');

    // ── Estado global ────────────────────────────────────────────
    let role = 'editor'; // 'editor' | 'observer'

    // ─────────────────────────────────────────────────────────────
    // ESTADO 0 → ESTADO 1: Entrar a sesión
    // ─────────────────────────────────────────────────────────────
    function enterSession(asRole) {
      role = asRole;
      hideEl(viewNoSession);
      showFlex(viewSession);
      setRole(asRole);
    }

    // A inicia sesión
    document.getElementById('startSessionBtn')?.addEventListener('click', () => {
      enterSession('editor');
    });

    // B se une con código
    document.getElementById('joinSessionBtn')?.addEventListener('click', () => {
      const input = document.getElementById('codeInput');
      const val   = (input?.value || '').trim();

      hideEl(document.getElementById('join-error'));
      hideEl(document.getElementById('join-error-403'));

      if (val.length < 4) {
        showFlex(document.getElementById('join-error'));
        return;
      }
      enterSession('observer');
    });

    document.getElementById('codeInput')?.addEventListener('input', () => {
      hideEl(document.getElementById('join-error'));
    });

    // ─────────────────────────────────────────────────────────────
    // TOGGLE Editor / Observador
    // ─────────────────────────────────────────────────────────────
    function setRole(newRole) {
      role = newRole;
      const isEditor = role === 'editor';

      btnEditor.classList.toggle('bg-zinc-800',    isEditor);
      btnEditor.classList.toggle('text-[#2e75b8]', isEditor);
      btnEditor.classList.toggle('shadow-sm',      isEditor);
      btnEditor.classList.toggle('text-zinc-500',  !isEditor);

      btnObserver.classList.toggle('bg-zinc-800',    !isEditor);
      btnObserver.classList.toggle('text-[#2e75b8]', !isEditor);
      btnObserver.classList.toggle('shadow-sm',      !isEditor);
      btnObserver.classList.toggle('text-zinc-500',  isEditor);

      viewEditor.classList.toggle('hidden',   !isEditor);
      viewObserver.classList.toggle('hidden', isEditor);

      endIcon.textContent  = isEditor ? 'stop_circle' : 'logout';
      endLabel.textContent = isEditor ? 'Finalizar sesión' : 'Salir de sesión';

      // Limpiar banners al cambiar de rol
      hideEl(bannerEditorDisc);
      hideEl(bannerLockAvailable);
    }

    btnEditor?.addEventListener('click',   () => setRole('editor'));
    btnObserver?.addEventListener('click', () => setRole('observer'));

    // ─────────────────────────────────────────────────────────────
    // EDITOR (A): Flujo de solicitud de lock — CU-031b pasos 3-6
    // ─────────────────────────────────────────────────────────────

    // Demo: simular que B solicita el control
    document.getElementById('simLockRequestBtn')?.addEventListener('click', () => {
      showBlock(lockRequestBanner);
    });

    // A cede el control a B
    document.getElementById('grantLockBtn')?.addEventListener('click', () => {
      hideEl(lockRequestBanner);

      // Actualizar badges: A → Solo lectura, B → Editando
      const badgeA = document.getElementById('badge-a');
      const badgeB = document.getElementById('badge-b');
      if (badgeA) {
        badgeA.className = 'text-[10px] text-zinc-500 bg-zinc-800 px-2 py-1 rounded border border-zinc-700';
        badgeA.textContent = 'Solo lectura';
      }
      if (badgeB) {
        badgeB.className = 'flex items-center gap-1 bg-green-900/20 text-green-400 px-2 py-1 rounded text-[10px] font-medium border border-green-900/40';
        badgeB.innerHTML = '<span class="material-symbols-outlined text-[12px]">edit</span>Editando';
      }

      // Actualizar indicador de estado
      const dot  = document.getElementById('editor-status-dot');
      const text = document.getElementById('editor-status-text');
      if (dot)  { dot.classList.replace('bg-green-500', 'bg-zinc-500'); dot.classList.remove('animate-pulse'); }
      if (text) { text.textContent = 'Sesión activa · Solo lectura'; text.classList.replace('text-green-400', 'text-zinc-400'); }

      showToast('Control cedido a Luisa García');
    });

    // A rechaza la solicitud de B
    document.getElementById('denyLockBtn')?.addEventListener('click', () => {
      hideEl(lockRequestBanner);
      showToast('Solicitud rechazada');
    });

    // ─────────────────────────────────────────────────────────────
    // OBSERVADOR (B): Máquina de estados del lock
    // watching → pending → watching/rejected
    // ─────────────────────────────────────────────────────────────
    function setObserverLockState(state) {
      hideEl(lockStateWatching);
      hideEl(lockStatePending);
      hideEl(lockStateRejected);

      if (state === 'watching')  showBlock(lockStateWatching);
      if (state === 'pending')   showBlock(lockStatePending);
      if (state === 'rejected')  showBlock(lockStateRejected);
    }

    // B solicita el control (CU-031b paso 1)
    document.getElementById('requestLockBtn')?.addEventListener('click', () => {
      setObserverLockState('pending');
    });

    // B cancela la solicitud
    document.getElementById('cancelLockBtn')?.addEventListener('click', () => {
      setObserverLockState('watching');
    });

    // B reintenta tras rechazo
    document.getElementById('retryLockBtn')?.addEventListener('click', () => {
      setObserverLockState('pending');
    });

    // Demo: A se desconecta (heartbeat timeout 30s — E2 de CU-031b)
    document.getElementById('simDisconnectBtn')?.addEventListener('click', () => {
      setObserverLockState('watching');
      showFlex(bannerEditorDisc);
      showFlex(bannerLockAvailable);
    });

    // B toma el lock disponible (A desconectado)
    document.getElementById('takeLockBtn')?.addEventListener('click', () => {
      hideEl(bannerEditorDisc);
      hideEl(bannerLockAvailable);
      showToast('Ahora tienes el control de edición');
    });

    // ─────────────────────────────────────────────────────────────
    // COPIAR código de invitación
    // ─────────────────────────────────────────────────────────────
    document.getElementById('copyBtn')?.addEventListener('click', function () {
      navigator.clipboard?.writeText('SC4F-9X2K').then(() => {
        const icon = this.querySelector('.material-symbols-outlined');
        icon.textContent = 'check';
        setTimeout(() => { icon.textContent = 'content_copy'; }, 1500);
      });
    });

    // ─────────────────────────────────────────────────────────────
    // FINALIZAR / SALIR de sesión
    // ─────────────────────────────────────────────────────────────
    document.getElementById('endBtn')?.addEventListener('click', () => {
      window.__navigate('tareas');
    });

    // ─────────────────────────────────────────────────────────────
    // TOAST helper
    // ─────────────────────────────────────────────────────────────
    function showToast(msg) {
      const t = document.createElement('div');
      t.className = 'fixed bottom-16 left-1/2 -translate-x-1/2 bg-zinc-800 border border-zinc-700 text-zinc-200 text-[11px] font-medium px-4 py-2 rounded-full shadow-lg z-50 transition-opacity duration-300';
      t.style.transform = 'translateX(-50%)';
      t.textContent = msg;
      document.body.appendChild(t);
      setTimeout(() => {
        t.style.opacity = '0';
        setTimeout(() => t.remove(), 300);
      }, 2000);
    }
  </script>
</PluginLayout>
