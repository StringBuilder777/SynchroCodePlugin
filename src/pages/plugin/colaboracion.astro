---
import PluginLayout from '../../layouts/PluginLayout.astro';
---
<PluginLayout title="SynchroCode — Colaborar" theme="dark">
  <div class="flex flex-col h-full bg-[#09090b]">
    <div class="p-4 border-b border-zinc-800 flex justify-between items-center bg-zinc-950 shrink-0">
      <button onclick="window.__navigate('tareas')" class="flex items-center text-[#2e75b8] text-sm font-medium bg-transparent border-0 cursor-pointer">
        <span class="material-symbols-outlined text-[16px] mr-1">chevron_left</span>Volver
      </button>
      <div class="flex items-center gap-2">
        <span class="flex items-center text-xs text-zinc-400">
          <span class="w-2 h-2 bg-green-500 rounded-full mr-1 animate-pulse"></span>Conectado
        </span>
      </div>
    </div>
    <nav class="flex border-b border-zinc-800 bg-zinc-950 shrink-0">
      <button onclick="window.__navigate('tareas')" class="flex-1 py-2 text-xs font-medium text-zinc-400 hover:text-zinc-200">Tareas</button>
      <button onclick="window.__navigate('chat')" class="flex-1 py-2 text-xs font-medium text-zinc-400 hover:text-zinc-200">Chat</button>
      <button class="flex-1 py-2 text-xs font-bold text-[#2e75b8] border-b-2 border-[#2e75b8]">Colaborar</button>
    </nav>
    <div class="flex bg-zinc-900/50 p-1 m-3 rounded-md border border-zinc-800 shrink-0">
      <button class="flex-1 py-1.5 flex items-center justify-center gap-1.5 bg-zinc-800 rounded text-[11px] font-medium text-[#2e75b8] shadow-sm">
        <span class="material-symbols-outlined text-[14px]">edit</span>Editor (A)
      </button>
      <button class="flex-1 py-1.5 flex items-center justify-center gap-1.5 text-[11px] font-medium text-zinc-500">
        <span class="material-symbols-outlined text-[14px]">visibility</span>Observador (B)
      </button>
    </div>
    <div class="flex-1 overflow-y-auto custom-scrollbar px-4 pb-4 space-y-5">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span class="w-2.5 h-2.5 bg-green-500 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-green-400">Sesión activa · Transmitiendo</span>
        </div>
        <span class="text-[10px] font-mono text-green-400 bg-green-900/30 px-1.5 py-0.5 rounded">middleware.ts</span>
      </div>
      <div class="bg-zinc-900 border border-zinc-800 rounded-lg p-4">
        <h3 class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider mb-3">Código de Invitación</h3>
        <div class="flex items-stretch gap-2">
          <div class="flex-1 bg-zinc-800/50 border border-zinc-700 rounded flex items-center justify-center py-2.5">
            <span class="text-lg font-mono font-semibold tracking-[0.2em] text-white">SC4F-9X2K</span>
          </div>
          <button class="px-3 bg-[#2e75b8]/20 text-[#2e75b8] border border-[#2e75b8]/40 rounded hover:bg-[#2e75b8]/30">
            <span class="material-symbols-outlined text-[18px]">content_copy</span>
          </button>
        </div>
        <p class="text-[11px] text-center text-zinc-500 mt-3 italic">Comparte este código · Expira en 30 min</p>
      </div>
      <div>
        <h3 class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider mb-3">Participantes (2)</h3>
        <div class="space-y-2">
          <div class="flex items-center justify-between bg-zinc-900 border border-zinc-800 rounded p-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-blue-900/50 flex items-center justify-center text-blue-400 text-xs font-bold">AR</div>
              <div><p class="text-sm font-semibold text-white/90">Alex Rivera</p><p class="text-[11px] text-zinc-500">Tú</p></div>
            </div>
            <div class="flex items-center gap-1.5 bg-green-900/20 text-green-400 px-2.5 py-1 rounded text-[11px] font-medium border border-green-900/40">
              <span class="material-symbols-outlined text-[12px]">edit</span>Editando
            </div>
          </div>
          <div class="flex items-center justify-between bg-zinc-900 border border-zinc-800 rounded p-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-green-900/30 flex items-center justify-center text-green-400 text-xs font-bold">LG</div>
              <div><p class="text-sm font-semibold text-white/90">Luisa García</p><p class="text-[11px] text-zinc-500">Observando</p></div>
            </div>
            <span class="text-[11px] text-zinc-500 bg-zinc-800 px-2.5 py-1 rounded border border-zinc-700">Solo lectura</span>
          </div>
        </div>
      </div>
    </div>
    <div class="p-4 border-t border-zinc-800 shrink-0">
      <button class="w-full py-2.5 border-2 border-red-500/50 text-red-400 rounded-md font-bold text-sm flex items-center justify-center gap-2 hover:bg-red-500/10 transition-colors">
        <span class="material-symbols-outlined text-[18px]">stop_circle</span>Finalizar sesión
      </button>
    </div>
  </div>
</PluginLayout>
