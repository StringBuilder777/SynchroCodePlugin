---
import PluginLayout from '../../layouts/PluginLayout.astro';
---
<PluginLayout title="SynchroCode — Tareas" theme="dark">
  <div class="flex flex-col h-full bg-[#09090b]">
    <!-- Header -->
    <header class="flex items-center justify-between px-4 py-3 border-b border-zinc-800 bg-zinc-950 shrink-0">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 shrink-0 rounded-full bg-[#2e75b8]/10 border border-[#2e75b8]/20 flex items-center justify-center text-xs font-bold text-[#2e75b8]">AR</div>
        <span class="text-[13px] font-semibold text-slate-200">Alex Rivera</span>
      </div>
      <div class="flex items-center gap-1">
        <button onclick="window.__navigate('notificaciones')" class="relative p-1.5 hover:bg-zinc-800 rounded transition-colors">
          <span class="material-symbols-outlined text-[20px] text-zinc-400">notifications</span>
          <span class="absolute top-1.5 right-1.5 flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
          </span>
        </button>
        <button class="p-1.5 hover:bg-zinc-800 rounded transition-colors text-zinc-400">
          <span class="material-symbols-outlined text-[20px]">more_vert</span>
        </button>
      </div>
    </header>

    <!-- Tabs -->
    <nav class="flex border-b border-zinc-800 px-2 bg-zinc-950 shrink-0">
      <button class="flex-1 py-2 text-[11px] font-medium border-b-2 border-[#2e75b8] text-[#2e75b8]">Tareas</button>
      <button onclick="window.__navigate('chat')" class="flex-1 py-2 text-[11px] font-medium border-b-2 border-transparent text-zinc-400 hover:text-slate-200">Chat</button>
      <button onclick="window.__navigate('colaboracion')" class="flex-1 py-2 text-[11px] font-medium border-b-2 border-transparent text-zinc-400 hover:text-slate-200">Colaborar</button>
    </nav>

    <!-- Search & Filters -->
    <div class="p-3 space-y-2 bg-zinc-900/50 shrink-0">
      <div class="relative">
        <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-zinc-400 text-[18px]">search</span>
        <input type="text" placeholder="Buscar tarea..."
          class="w-full pl-9 pr-3 py-1.5 text-xs bg-zinc-900 border border-zinc-800 rounded focus:ring-1 focus:ring-[#2e75b8] outline-none text-slate-200 placeholder:text-zinc-500" />
      </div>
      <div class="flex gap-2 overflow-x-auto hide-scrollbar pb-1">
        <button class="shrink-0 px-3 py-1 text-[10px] font-medium bg-[#2e75b8] text-white rounded-full">Todos</button>
        <button class="shrink-0 px-3 py-1 text-[10px] font-medium bg-zinc-900 border border-zinc-800 text-zinc-400 rounded-full hover:bg-zinc-800">Pendiente</button>
        <button class="shrink-0 px-3 py-1 text-[10px] font-medium bg-zinc-900 border border-zinc-800 text-zinc-400 rounded-full hover:bg-zinc-800">En Proceso</button>
        <button class="shrink-0 px-3 py-1 text-[10px] font-medium bg-zinc-900 border border-zinc-800 text-zinc-400 rounded-full hover:bg-zinc-800">Terminada</button>
      </div>
    </div>

    <!-- Task List -->
    <div class="flex-1 overflow-y-auto custom-scrollbar p-3 space-y-3">
      <!-- Task 1 -->
      <div class="p-3 bg-zinc-900 border border-zinc-800 rounded-lg hover:border-[#2e75b8]/50 transition-colors cursor-pointer"
           onclick="window.__navigate('tarea-detalle')">
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-[13px] font-semibold text-slate-100 leading-tight">Implementar Auth Middleware</h3>
          <span class="flex h-2 w-2 rounded-full bg-red-500 mt-1 shrink-0"></span>
        </div>
        <div class="text-[10px] text-zinc-400 mb-2 flex items-center gap-1">
          <span class="material-symbols-outlined text-[14px]">folder</span>SynchroCode-Web
        </div>
        <div class="flex flex-wrap gap-1.5 mb-3">
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-red-950/50 text-red-400 border border-red-900/50 uppercase">High</span>
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-purple-950/50 text-purple-400 border border-purple-900/50 uppercase">In Progress</span>
        </div>
        <div class="flex items-center justify-between mt-2">
          <div class="flex items-center gap-1 text-[10px] text-zinc-400">
            <span class="material-symbols-outlined text-[14px]">calendar_today</span>24 Oct 2023
          </div>
          <span class="text-[11px] font-semibold text-[#2e75b8] flex items-center gap-1">
            Ver detalle <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
          </span>
        </div>
      </div>

      <!-- Task 2 -->
      <div class="p-3 bg-zinc-900 border border-zinc-800 rounded-lg hover:border-[#2e75b8]/50 transition-colors cursor-pointer"
           onclick="window.__navigate('tarea-detalle')">
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-[13px] font-semibold text-slate-100 leading-tight">Refactorizar componentes UI</h3>
          <span class="flex h-2 w-2 rounded-full bg-yellow-500 mt-1 shrink-0"></span>
        </div>
        <div class="text-[10px] text-zinc-400 mb-2 flex items-center gap-1">
          <span class="material-symbols-outlined text-[14px]">folder</span>Design-System
        </div>
        <div class="flex flex-wrap gap-1.5 mb-3">
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-yellow-950/50 text-yellow-400 border border-yellow-900/50 uppercase">Medium</span>
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-blue-950/50 text-blue-400 border border-blue-900/50 uppercase">Pending</span>
        </div>
        <div class="flex items-center justify-between mt-2">
          <div class="flex items-center gap-1 text-[10px] text-zinc-400">
            <span class="material-symbols-outlined text-[14px]">calendar_today</span>28 Oct 2023
          </div>
          <span class="text-[11px] font-semibold text-[#2e75b8] flex items-center gap-1">
            Ver detalle <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
          </span>
        </div>
      </div>

      <!-- Task 3 -->
      <div class="p-3 bg-zinc-900 border border-zinc-800 rounded-lg opacity-70 cursor-pointer">
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-[13px] font-semibold text-slate-100 leading-tight line-through opacity-60">Configurar entorno Docker</h3>
          <span class="flex h-2 w-2 rounded-full bg-green-500 mt-1 shrink-0"></span>
        </div>
        <div class="text-[10px] text-zinc-400 mb-2 flex items-center gap-1">
          <span class="material-symbols-outlined text-[14px]">folder</span>Infrastructure
        </div>
        <div class="flex flex-wrap gap-1.5">
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-green-950/50 text-green-400 border border-green-900/50 uppercase">Low</span>
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-emerald-950/50 text-emerald-400 border border-emerald-900/50 uppercase">Finished</span>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="p-2 border-t border-zinc-800 flex items-center justify-between bg-zinc-900/50 shrink-0">
      <div class="flex items-center gap-1 text-[10px] text-zinc-400">
        <span class="material-symbols-outlined text-[12px]">code</span>v1.2.4-stable
      </div>
      <div class="flex items-center gap-2">
        <span class="flex h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-[10px] text-zinc-400">Connected</span>
      </div>
    </footer>
  </div>
</PluginLayout>
