---
import PluginLayout from '../../layouts/PluginLayout.astro';
---
<PluginLayout title="SynchroCode — Chat" theme="dark">
  <div class="flex flex-col h-full bg-[var(--plugin-bg)]">

    <!-- Header (igual que Tareas) -->
    <header class="flex items-center justify-between px-4 py-3 border-b border-zinc-800 bg-zinc-950 shrink-0">
      <div class="flex items-center gap-2">
        <div class="w-7 h-7 shrink-0 rounded-full bg-[#2e75b8]/10 border border-[#2e75b8]/20 flex items-center justify-center text-xs font-bold text-[#2e75b8]">AR</div>
        <span class="text-[13px] font-semibold text-slate-200">Alex Rivera</span>
      </div>
      <div class="flex items-center gap-1">
        <button onclick="window.__navigate('notificaciones')" class="relative p-1.5 hover:bg-zinc-800 rounded transition-colors">
          <span class="material-symbols-outlined text-[20px] text-zinc-400">notifications</span>
          <span class="absolute top-1.5 right-1.5 flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
          </span>
        </button>
        <button class="p-1.5 hover:bg-zinc-800 rounded transition-colors text-zinc-400">
          <span class="material-symbols-outlined text-[20px]">more_vert</span>
        </button>
      </div>
    </header>

    <!-- Canales -->
    <div class="flex gap-1.5 px-3 py-2 border-b border-zinc-800 bg-zinc-950 overflow-x-auto hide-scrollbar shrink-0">
      <button data-channel="general"
        class="channel-btn shrink-0 flex items-center gap-1 px-2.5 py-1 rounded text-[11px] font-medium bg-zinc-800 text-[#2e75b8] border border-zinc-700">
        <span class="text-zinc-500">#</span>general
        <span class="ml-1 px-1 py-0.5 bg-red-500 text-white text-[8px] rounded-full leading-none">3</span>
      </button>
      <button data-channel="backend"
        class="channel-btn shrink-0 flex items-center gap-1 px-2.5 py-1 rounded text-[11px] font-medium text-zinc-400 hover:bg-zinc-800 hover:text-zinc-200 border border-transparent">
        <span class="text-zinc-600">#</span>backend
      </button>
      <button data-channel="frontend"
        class="channel-btn shrink-0 flex items-center gap-1 px-2.5 py-1 rounded text-[11px] font-medium text-zinc-400 hover:bg-zinc-800 hover:text-zinc-200 border border-transparent">
        <span class="text-zinc-600">#</span>frontend
      </button>
      <button data-channel="devops"
        class="channel-btn shrink-0 flex items-center gap-1 px-2.5 py-1 rounded text-[11px] font-medium text-zinc-400 hover:bg-zinc-800 hover:text-zinc-200 border border-transparent">
        <span class="text-zinc-600">#</span>devops
      </button>
    </div>

    <!-- Mensajes por canal -->
    <div class="flex-1 overflow-y-auto custom-scrollbar">

      <!-- #general -->
      <div id="channel-general" class="channel-content p-4 space-y-4">
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-zinc-700 text-zinc-100 flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">CM</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Carlos Mendoza</span>
              <span class="text-[9px] text-zinc-600">10:30 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">¿Alguien puede revisar el PR de auth antes del jueves?</div>
          </div>
        </div>
        <div class="flex gap-2 justify-end">
          <div class="flex-grow min-w-0 text-right">
            <div class="flex items-baseline gap-2 justify-end mb-1">
              <span class="text-[9px] text-zinc-600">11:15 AM</span>
              <span class="text-[12px] font-semibold text-zinc-200">Tú</span>
            </div>
            <div class="bg-[#2e75b8]/80 px-3 py-2 rounded-lg text-[12px] text-white inline-block max-w-full">Sí, lo veo hoy en la tarde. ¿Tiene tests?</div>
          </div>
          <div class="w-8 h-8 rounded bg-[#2e75b8]/60 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">AR</div>
        </div>
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-emerald-700 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">LG</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Luisa García</span>
              <span class="text-[9px] text-zinc-600">11:30 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">Yo lo puedo revisar también 👀</div>
          </div>
        </div>
        <div class="flex items-center py-1">
          <div class="flex-grow border-t border-zinc-800"></div>
          <span class="px-2 text-[9px] text-zinc-600 uppercase tracking-wider font-semibold">Hoy</span>
          <div class="flex-grow border-t border-zinc-800"></div>
        </div>
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-zinc-700 text-zinc-100 flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">CM</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Carlos Mendoza</span>
              <span class="text-[9px] text-zinc-600">09:00 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">PR mergeado 🎉 El middleware ya está en main.</div>
          </div>
        </div>
        <div class="flex gap-2 justify-end">
          <div class="flex-grow min-w-0 text-right">
            <div class="flex items-baseline gap-2 justify-end mb-1">
              <span class="text-[9px] text-zinc-600">09:05 AM</span>
              <span class="text-[12px] font-semibold text-zinc-200">Tú</span>
            </div>
            <div class="bg-[#2e75b8]/80 px-3 py-2 rounded-lg text-[12px] text-white inline-block max-w-full">Perfecto. Ahora toca el Realtime integration.</div>
          </div>
          <div class="w-8 h-8 rounded bg-[#2e75b8]/60 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">AR</div>
        </div>
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-zinc-700 text-zinc-100 flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">CM</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Carlos Mendoza</span>
              <span class="text-[9px] text-zinc-600">09:12 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">Ojo con el rate limit de Supabase en realtime 🚨</div>
          </div>
        </div>
      </div>

      <!-- #backend -->
      <div id="channel-backend" class="channel-content hidden p-4 space-y-4">
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-orange-700 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">JR</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Jorge Ruiz</span>
              <span class="text-[9px] text-zinc-600">08:45 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">Quarkus 3.6 ya soporta virtual threads nativo. Deberíamos migrar.</div>
          </div>
        </div>
        <div class="flex gap-2 justify-end">
          <div class="flex-grow min-w-0 text-right">
            <div class="flex items-baseline gap-2 justify-end mb-1">
              <span class="text-[9px] text-zinc-600">09:01 AM</span>
              <span class="text-[12px] font-semibold text-zinc-200">Tú</span>
            </div>
            <div class="bg-[#2e75b8]/80 px-3 py-2 rounded-lg text-[12px] text-white inline-block max-w-full">Buena idea. ¿Ya probaste el benchmark?</div>
          </div>
          <div class="w-8 h-8 rounded bg-[#2e75b8]/60 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">AR</div>
        </div>
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-orange-700 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">JR</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Jorge Ruiz</span>
              <span class="text-[9px] text-zinc-600">09:15 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">Sí, 40% menos latencia en endpoints pesados 🔥</div>
          </div>
        </div>
        <div class="flex gap-2 justify-end">
          <div class="flex-grow min-w-0 text-right">
            <div class="flex items-baseline gap-2 justify-end mb-1">
              <span class="text-[9px] text-zinc-600">09:18 AM</span>
              <span class="text-[12px] font-semibold text-zinc-200">Tú</span>
            </div>
            <div class="bg-[#2e75b8]/80 px-3 py-2 rounded-lg text-[12px] text-white inline-block max-w-full">Lo incluimos en el sprint de noviembre.</div>
          </div>
          <div class="w-8 h-8 rounded bg-[#2e75b8]/60 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">AR</div>
        </div>
      </div>

      <!-- #frontend -->
      <div id="channel-frontend" class="channel-content hidden p-4 space-y-4">
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-emerald-700 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">LG</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Luisa García</span>
              <span class="text-[9px] text-zinc-600">10:00 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">Moví los componentes de auth a una carpeta propia. Revisen el PR #52.</div>
          </div>
        </div>
        <div class="flex gap-2 justify-end">
          <div class="flex-grow min-w-0 text-right">
            <div class="flex items-baseline gap-2 justify-end mb-1">
              <span class="text-[9px] text-zinc-600">10:05 AM</span>
              <span class="text-[12px] font-semibold text-zinc-200">Tú</span>
            </div>
            <div class="bg-[#2e75b8]/80 px-3 py-2 rounded-lg text-[12px] text-white inline-block max-w-full">Visto. Le doy aprobación en un rato.</div>
          </div>
          <div class="w-8 h-8 rounded bg-[#2e75b8]/60 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">AR</div>
        </div>
        <div class="flex items-center gap-2 text-[11px] text-zinc-500 italic py-2">
          <span class="material-symbols-outlined text-[14px]">edit</span>
          Luisa García está escribiendo...
        </div>
      </div>

      <!-- #devops -->
      <div id="channel-devops" class="channel-content hidden p-4 space-y-4">
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-purple-700 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">MR</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Marcos Ríos</span>
              <span class="text-[9px] text-zinc-600">07:50 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">Pipeline de CI roto 🚨 Falla en el step de Docker build.</div>
          </div>
        </div>
        <div class="flex gap-2 justify-end">
          <div class="flex-grow min-w-0 text-right">
            <div class="flex items-baseline gap-2 justify-end mb-1">
              <span class="text-[9px] text-zinc-600">08:00 AM</span>
              <span class="text-[12px] font-semibold text-zinc-200">Tú</span>
            </div>
            <div class="bg-[#2e75b8]/80 px-3 py-2 rounded-lg text-[12px] text-white inline-block max-w-full">Veo el log. ¿Cuál es el error exacto?</div>
          </div>
          <div class="w-8 h-8 rounded bg-[#2e75b8]/60 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">AR</div>
        </div>
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-purple-700 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">MR</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Marcos Ríos</span>
              <span class="text-[9px] text-zinc-600">08:03 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] font-mono text-red-400 inline-block max-w-full text-[11px]">COPY failed: file not found in build context: "dist/"</div>
          </div>
        </div>
        <div class="flex gap-2 justify-end">
          <div class="flex-grow min-w-0 text-right">
            <div class="flex items-baseline gap-2 justify-end mb-1">
              <span class="text-[9px] text-zinc-600">08:07 AM</span>
              <span class="text-[12px] font-semibold text-zinc-200">Tú</span>
            </div>
            <div class="bg-[#2e75b8]/80 px-3 py-2 rounded-lg text-[12px] text-white inline-block max-w-full">Falta el paso de build antes del COPY. Lo parcheo ahora.</div>
          </div>
          <div class="w-8 h-8 rounded bg-[#2e75b8]/60 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">AR</div>
        </div>
        <div class="flex gap-2">
          <div class="w-8 h-8 rounded bg-purple-700 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">MR</div>
          <div class="flex-grow min-w-0">
            <div class="flex items-baseline gap-2 mb-1">
              <span class="text-[12px] font-semibold text-zinc-200">Marcos Ríos</span>
              <span class="text-[9px] text-zinc-600">08:25 AM</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 px-3 py-2 rounded-lg text-[12px] text-zinc-200 inline-block max-w-full">Pipeline verde ✅ Gracias!</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="p-3 border-t border-zinc-800 bg-zinc-950 shrink-0">
      <div class="relative">
        <textarea id="chatInput" rows="2"
          placeholder="Mensaje en #general · Enter para enviar · Shift+Enter nueva línea"
          class="w-full border border-zinc-800 bg-zinc-900 text-zinc-200 rounded-lg text-[12px] p-3 pr-12 focus:ring-1 focus:ring-[#2e75b8]/50 resize-none placeholder-zinc-600 outline-none"></textarea>
        <button id="sendBtn" class="absolute bottom-2.5 right-2.5 bg-[#2e75b8]/20 p-1.5 rounded text-[#2e75b8] hover:bg-[#2e75b8]/40 transition-colors">
          <span class="material-symbols-outlined text-[18px]">send</span>
        </button>
      </div>
    </div>

    <!-- Footer -->
    <footer class="p-2 border-t border-zinc-800 bg-zinc-950 flex items-center justify-around shrink-0">
      <button onclick="window.__navigate('dashboard')" class="flex flex-col items-center gap-0.5 px-2 py-1 text-zinc-500 hover:text-zinc-300">
        <span class="material-symbols-outlined text-[20px]">grid_view</span>
        <span class="text-[9px] font-medium">Dashboard</span>
      </button>
      <button onclick="window.__navigate('tareas')" class="flex flex-col items-center gap-0.5 px-2 py-1 text-zinc-500 hover:text-zinc-300">
        <span class="material-symbols-outlined text-[20px]">list_alt</span>
        <span class="text-[9px] font-medium">Tareas</span>
      </button>
      <button onclick="window.__navigate('chat')" class="flex flex-col items-center gap-0.5 px-2 py-1 text-[#2e75b8]">
        <span class="material-symbols-outlined text-[20px]">forum</span>
        <span class="text-[9px] font-medium">Chat</span>
      </button>
      <button onclick="window.__navigate('colaboracion')" class="flex flex-col items-center gap-0.5 px-2 py-1 text-zinc-500 hover:text-zinc-300">
        <span class="material-symbols-outlined text-[20px]">screen_share</span>
        <span class="text-[9px] font-medium">Colab</span>
      </button>
    </footer>
  </div>

  <script>
    const vscode = window.__vscode || null;

    // ── Canal activo ─────────────────────────────────────────────
    let activeChannel = 'general';

    const channelBtns = document.querySelectorAll('.channel-btn');
    const channelContents = document.querySelectorAll('.channel-content');
    const chatInput = document.getElementById('chatInput');

    const placeholders = {
      general:  'Mensaje en #general · Enter para enviar · Shift+Enter nueva línea',
      backend:  'Mensaje en #backend · Enter para enviar · Shift+Enter nueva línea',
      frontend: 'Mensaje en #frontend · Enter para enviar · Shift+Enter nueva línea',
      devops:   'Mensaje en #devops · Enter para enviar · Shift+Enter nueva línea',
    };

    function switchChannel(name) {
      activeChannel = name;
      // Actualizar botones
      channelBtns.forEach(btn => {
        const isActive = btn.dataset.channel === name;
        btn.classList.toggle('bg-zinc-800', isActive);
        btn.classList.toggle('text-[#2e75b8]', isActive);
        btn.classList.toggle('border-zinc-700', isActive);
        btn.classList.toggle('text-zinc-400', !isActive);
        btn.classList.toggle('border-transparent', !isActive);
        // Limpiar badge al ver el canal
        if (isActive) {
          const badge = btn.querySelector('span[class*="bg-red-500"]');
          if (badge) badge.remove();
        }
      });
      // Mostrar contenido
      channelContents.forEach(c => {
        c.classList.toggle('hidden', c.id !== 'channel-' + name);
      });
      // Actualizar placeholder
      if (chatInput) chatInput.placeholder = placeholders[name] ?? placeholders.general;
      // Scroll al final
      const content = document.getElementById('channel-' + name);
      if (content) content.scrollTop = content.scrollHeight;
    }

    channelBtns.forEach(btn => {
      btn.addEventListener('click', () => switchChannel(btn.dataset.channel));
    });

    // Scroll inicial al final del canal activo
    switchChannel('general');

    // ── Enviar mensaje ────────────────────────────────────────────
    function sendMessage() {
      const text = chatInput?.value.trim();
      if (!text) return;
      chatInput.value = '';

      const container = document.getElementById('channel-' + activeChannel);
      if (!container) return;

      const msg = document.createElement('div');
      msg.className = 'flex gap-2 justify-end';
      msg.innerHTML = `
        <div class="flex-grow min-w-0 text-right">
          <div class="flex items-baseline gap-2 justify-end mb-1">
            <span class="text-[9px] text-zinc-600">${new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</span>
            <span class="text-[12px] font-semibold text-zinc-200">Tú</span>
          </div>
          <div class="bg-[#2e75b8]/80 px-3 py-2 rounded-lg text-[12px] text-white inline-block max-w-full break-words">${text.replace(/</g,'&lt;')}</div>
        </div>
        <div class="w-8 h-8 rounded bg-[#2e75b8]/60 text-white flex items-center justify-center text-[10px] font-bold shrink-0 mt-0.5">AR</div>
      `;
      container.appendChild(msg);
      container.scrollTop = container.scrollHeight;
    }

    chatInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });
    document.getElementById('sendBtn')?.addEventListener('click', sendMessage);
  </script>
</PluginLayout>
