---
import PluginLayout from '../../layouts/PluginLayout.astro';
---
<PluginLayout title="SynchroCode — Cambiar Estado" theme="dark">
  <div class="flex flex-col h-full bg-[var(--plugin-bg)] relative">

    <!-- Blurred background: task detail preview -->
    <div class="opacity-30 pointer-events-none select-none shrink-0">
      <div class="px-5 py-4 border-b border-zinc-800">
        <button class="flex items-center text-[#2e75b8] text-xs font-medium mb-3">
          <span class="material-symbols-outlined text-[16px] mr-1">chevron_left</span>Mis Tareas
        </button>
        <h1 id="previewTitle" class="text-base font-bold text-zinc-100 leading-tight mb-1">Cargando...</h1>
        <p class="text-xs text-zinc-500">SC-TASK</p>
        <div class="flex flex-wrap gap-2 mt-3" id="previewTags">
          <!-- Tags will be injected here -->
        </div>
      </div>
      <div class="grid grid-cols-2 border-b border-zinc-800">
        <div class="p-3 border-r border-zinc-800">
          <p class="text-[10px] uppercase font-bold text-zinc-500 mb-1">PROYECTO</p>
          <p id="previewProject" class="text-xs text-zinc-300">...</p>
        </div>
        <div class="p-3">
          <p class="text-[10px] uppercase font-bold text-zinc-500 mb-1">RESPONSABLE</p>
          <p id="previewAssignee" class="text-xs text-zinc-300">...</p>
        </div>
      </div>
    </div>

    <!-- Status Dropdown Overlay -->
    <div class="mx-4 mt-4 bg-zinc-900 border border-zinc-700 rounded-lg shadow-2xl overflow-hidden z-10 relative">
      <div class="p-4 border-b border-zinc-800 bg-zinc-950">
        <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">CAMBIAR ESTADO A:</p>
        <div id="statusError" class="hidden mt-3 text-xs text-red-300 bg-red-900/20 border border-red-800/50 rounded px-3 py-2"></div>
      </div>

      <div class="p-2 space-y-1" id="statusButtonsContainer">
        <div class="flex items-center justify-center p-4">
          <span class="material-symbols-outlined animate-spin text-zinc-500">autorenew</span>
        </div>
      </div>

      <!-- Cancel -->
      <button onclick="window.__navigate('tarea-detalle')"
        class="w-full p-4 text-xs text-zinc-500 hover:text-zinc-100 text-center border-t border-zinc-800 transition-colors cursor-pointer bg-transparent border-x-0 border-b-0">
        Cancelar
      </button>
    </div>
  </div>

  <script>
    import { tasksService, type TaskStatus } from '../../lib/tasks';

    const statusError = document.getElementById('statusError');
    const container = document.getElementById('statusButtonsContainer');

    function setError(message: string) {
      if (!statusError) return;
      statusError.textContent = message;
      statusError.classList.remove('hidden');
    }

    function clearError() {
      if (!statusError) return;
      statusError.textContent = '';
      statusError.classList.add('hidden');
    }

    async function updateStatus(nextStatus: TaskStatus) {
      clearError();
      const taskId = localStorage.getItem('synchrocode-current-task-id');
      if (!taskId) {
        setError('No se encontró la tarea seleccionada.');
        return;
      }

      if (container) {
        const buttons = container.querySelectorAll('button');
        buttons.forEach(b => {
          b.disabled = true;
          b.classList.add('opacity-50', 'cursor-not-allowed');
        });
      }

      try {
        await tasksService.updateStatus(taskId, nextStatus);
        const navigate = (window as any).__navigate;
        if (typeof navigate === 'function') {
          navigate('tarea-detalle');
          return;
        }
        window.location.href = '/plugin/tarea-detalle';
      } catch (error) {
        const message = error instanceof Error ? error.message : 'No se pudo actualizar el estado de la tarea.';
        setError(message);
        if (container) {
          const buttons = container.querySelectorAll('button');
          buttons.forEach(b => {
            b.disabled = false;
            b.classList.remove('opacity-50', 'cursor-not-allowed');
          });
        }
      }
    }

    // Assign globally to be called from inline onclick handlers
    (window as any).updateTaskStatus = updateStatus;

    async function init() {
      const taskId = localStorage.getItem('synchrocode-current-task-id');
      if (!taskId) {
        setError('No se encontró la tarea seleccionada.');
        if (container) container.innerHTML = '';
        return;
      }

      try {
        const task = await tasksService.getById(taskId);
        
        // Update Preview
        const titleEl = document.getElementById('previewTitle');
        const projectEl = document.getElementById('previewProject');
        const assigneeEl = document.getElementById('previewAssignee');
        const tagsEl = document.getElementById('previewTags');
        
        if (titleEl) titleEl.textContent = task.title || 'Sin título';
        if (projectEl) projectEl.textContent = task.projectName || 'Sin proyecto';
        if (assigneeEl) assigneeEl.textContent = task.assignee || 'Sin asignar';
        
        if (tagsEl) {
          tagsEl.innerHTML = '';
          if (task.priority) {
            const prioClass = task.priority === 'alta' ? 'bg-red-900/30 text-red-400 border-red-800/50' : 
                              task.priority === 'media' ? 'bg-amber-900/30 text-amber-400 border-amber-800/50' : 
                              'bg-green-900/30 text-green-400 border-green-800/50';
            tagsEl.innerHTML += `<span class="px-2 py-0.5 ${prioClass} text-[10px] font-bold rounded border uppercase">${task.priority === 'alta' ? '! ALTA' : task.priority}</span>`;
          }
          if (task.status) {
            const statClass = task.status === 'pendiente' ? 'bg-zinc-800 text-zinc-400 border-zinc-700' : 
                              task.status === 'en_proceso' ? 'bg-purple-900/30 text-purple-400 border-purple-800/50' : 
                              'bg-green-900/30 text-green-400 border-green-800/50';
            const statLabel = task.status.replace('_', ' ').toUpperCase();
            tagsEl.innerHTML += `<span class="px-2 py-0.5 ${statClass} text-[10px] font-bold rounded border uppercase">${statLabel}</span>`;
          }
        }

        // Render Status Buttons
        if (container) {
          const statuses: { id: TaskStatus, label: string, color: string, colorBg: string, colorBorder: string }[] = [
            { id: 'pendiente', label: 'Pendiente', color: 'bg-zinc-500', colorBg: 'bg-zinc-800/50', colorBorder: 'border-zinc-500' },
            { id: 'en_proceso', label: 'En Proceso', color: 'bg-purple-500', colorBg: 'bg-purple-900/20', colorBorder: 'border-purple-500' },
            { id: 'terminado', label: 'Terminada', color: 'bg-green-500', colorBg: 'bg-green-900/20', colorBorder: 'border-green-500' }
          ];

          container.innerHTML = statuses.map(s => {
            const isActive = task.status === s.id;
            if (isActive) {
              return `
                <div class="flex items-center px-4 py-3 ${s.colorBg} text-white rounded border-l-4 ${s.colorBorder}">
                  <span class="w-3 h-3 ${s.color} rounded-full mr-3 shrink-0"></span>
                  <span class="text-sm font-semibold">${s.label}</span>
                  <span class="material-symbols-outlined text-[16px] ml-auto ${s.color.replace('bg-', 'text-')}">check</span>
                </div>
              `;
            } else {
              return `
                <button onclick="window.updateTaskStatus('${s.id}')"
                  class="w-full flex items-center px-4 py-3 hover:bg-zinc-800 cursor-pointer rounded transition-colors text-left">
                  <span class="w-3 h-3 ${s.color} rounded-full mr-3 shrink-0"></span>
                  <span class="text-sm text-zinc-300">${s.label}</span>
                </button>
              `;
            }
          }).join('');
        }

      } catch (err) {
        console.error(err);
        setError('Error al cargar la tarea.');
        if (container) container.innerHTML = '';
      }
    }

    document.addEventListener('DOMContentLoaded', init);
    window.addEventListener('viewChanged', (e: any) => {
      if (e.detail?.view === 'cambiar-estado') init();
    });
  </script>
</PluginLayout>
