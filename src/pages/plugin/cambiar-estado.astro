---
import PluginLayout from '../../layouts/PluginLayout.astro';
---
<PluginLayout title="SynchroCode — Cambiar Estado" theme="dark">
  <div class="flex flex-col h-full bg-[#09090b] relative">
    <!-- Background blurred -->
    <div class="opacity-30 pointer-events-none select-none px-5 py-4 border-b border-zinc-800">
      <h1 class="text-base font-bold text-zinc-100">Implementar Auth Middleware</h1>
      <p class="text-xs text-zinc-500">SC-1024</p>
      <div class="flex gap-2 mt-3">
        <span class="px-2 py-0.5 bg-red-900/30 text-red-400 text-[10px] font-bold rounded border border-red-800/50">ALTA</span>
        <span class="px-2 py-0.5 bg-purple-900/30 text-purple-400 text-[10px] font-bold rounded border border-purple-800/50">EN PROCESO</span>
      </div>
    </div>

    <!-- Status Dropdown -->
    <div class="mx-4 mt-4 bg-zinc-900 border border-zinc-700 rounded-lg shadow-2xl overflow-hidden">
      <div class="p-4 border-b border-zinc-800 bg-zinc-950">
        <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">CAMBIAR ESTADO A:</p>
      </div>
      <div class="p-2 space-y-1">
        <button class="w-full flex items-center px-4 py-3 hover:bg-zinc-800 cursor-pointer rounded transition-colors text-left">
          <span class="w-3 h-3 bg-zinc-600 rounded-full mr-3"></span>
          <span class="text-sm text-zinc-300">Pendiente</span>
        </button>
        <div class="flex items-center px-4 py-3 bg-purple-900/20 text-purple-300 rounded border-l-4 border-purple-500">
          <span class="w-3 h-3 bg-purple-500 rounded-full mr-3"></span>
          <span class="text-sm font-semibold">En Proceso</span>
          <span class="material-symbols-outlined text-[16px] ml-auto text-purple-500">check</span>
        </div>
        <button id="doneBtn" class="w-full flex items-center px-4 py-3 hover:bg-zinc-800 cursor-pointer rounded transition-colors text-left">
          <span class="w-3 h-3 bg-green-500 rounded-full mr-3"></span>
          <span class="text-sm text-zinc-300">Terminada</span>
        </button>
      </div>
      <button onclick="window.__navigate('tarea-detalle')"
        class="w-full p-4 text-xs text-zinc-500 hover:text-zinc-100 text-center border-t border-zinc-800 transition-colors">
        Cancelar
      </button>
    </div>
  </div>

  <script>
    document.getElementById('doneBtn')?.addEventListener('click', () => {
      const vscode = (typeof acquireVsCodeApi !== 'undefined') ? acquireVsCodeApi() : null;
      if (vscode) {
        vscode.postMessage({ command: 'changeStatus', taskId: 'SC-1024', status: 'TERMINADA' });
      }
      window.__navigate('tareas');
    });
  </script>
</PluginLayout>
