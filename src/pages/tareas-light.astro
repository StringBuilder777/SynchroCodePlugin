---
import WebviewLayout from '../layouts/WebviewLayout.astro';
---
<WebviewLayout title="SynchroCode — Tareas (Claro)" theme="light" activeFile="task-list.ts">
  <!-- Tasks Panel (Light) -->
  <div class="flex flex-col h-full bg-[#f3f3f3]">
    <!-- Header -->
    <header class="flex items-center justify-between px-4 py-3 border-b border-slate-200 bg-white shrink-0">
      <div class="flex items-center gap-2 overflow-hidden">
        <div class="w-7 h-7 shrink-0 rounded-full bg-[#2e75b8]/10 border border-[#2e75b8]/20 flex items-center justify-center text-xs font-bold text-[#2e75b8]">
          AR
        </div>
        <h2 class="text-[13px] font-semibold truncate text-slate-800">Alex Rivera</h2>
      </div>
      <div class="flex items-center gap-1">
        <button class="relative p-1.5 hover:bg-slate-100 rounded transition-colors">
          <span class="material-symbols-outlined text-[20px] text-slate-600">notifications</span>
          <span class="absolute top-1.5 right-1.5 flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
          </span>
        </button>
        <button class="p-1.5 hover:bg-slate-100 rounded transition-colors text-slate-600">
          <span class="material-symbols-outlined text-[20px]">more_vert</span>
        </button>
      </div>
    </header>

    <!-- Navigation Tabs -->
    <nav class="flex border-b border-slate-200 px-2 bg-white shrink-0">
      <button class="flex-1 py-2 text-[11px] font-medium border-b-2 border-[#2e75b8] text-[#2e75b8]">Tareas</button>
      <button class="flex-1 py-2 text-[11px] font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-800 transition-colors">Chat</button>
      <button class="flex-1 py-2 text-[11px] font-medium border-b-2 border-transparent text-slate-500 hover:text-slate-800 transition-colors">Colaborar</button>
    </nav>

    <!-- Search & Filters -->
    <div class="p-3 space-y-2 bg-slate-50 shrink-0">
      <div class="relative">
        <span class="material-symbols-outlined absolute left-2.5 top-1/2 -translate-y-1/2 text-slate-400 text-[18px]">search</span>
        <input
          type="text"
          placeholder="Buscar tarea..."
          class="w-full pl-9 pr-3 py-1.5 text-xs bg-white border border-slate-200 rounded focus:ring-1 focus:ring-[#2e75b8] outline-none text-slate-700 placeholder:text-slate-400"
        />
      </div>
      <div class="flex gap-2 overflow-x-auto hide-scrollbar pb-1">
        <button class="shrink-0 px-3 py-1 text-[10px] font-medium bg-[#2e75b8] text-white rounded-full shadow-sm">Todos</button>
        <button class="shrink-0 px-3 py-1 text-[10px] font-medium bg-white border border-slate-200 text-slate-500 rounded-full hover:bg-slate-50 transition-colors">Pendiente</button>
        <button class="shrink-0 px-3 py-1 text-[10px] font-medium bg-white border border-slate-200 text-slate-500 rounded-full hover:bg-slate-50 transition-colors">En Proceso</button>
        <button class="shrink-0 px-3 py-1 text-[10px] font-medium bg-white border border-slate-200 text-slate-500 rounded-full hover:bg-slate-50 transition-colors">Terminada</button>
      </div>
    </div>

    <!-- Task List -->
    <div class="flex-1 overflow-y-auto custom-scrollbar p-3 space-y-3 bg-[#f3f3f3]">
      <!-- Task Card 1 — High / In Progress -->
      <div class="p-3 bg-white border border-slate-200 rounded-lg shadow-sm hover:border-[#2e75b8]/50 transition-colors">
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-[13px] font-semibold text-slate-800 leading-tight">Implementar Auth Middleware</h3>
          <span class="flex h-2 w-2 rounded-full bg-red-500 mt-1 shrink-0"></span>
        </div>
        <div class="text-[10px] text-slate-400 mb-3 flex items-center gap-1">
          <span class="material-symbols-outlined text-[14px]">folder</span>
          <span>SynchroCode-Web</span>
        </div>
        <div class="flex flex-wrap gap-1.5 mb-3">
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-red-100 text-red-700 uppercase tracking-wider">High</span>
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-purple-100 text-purple-700 uppercase tracking-wider">In Progress</span>
        </div>
        <div class="flex items-center justify-between mt-3">
          <div class="flex items-center gap-1 text-[10px] text-slate-400">
            <span class="material-symbols-outlined text-[14px]">calendar_today</span>
            <span>24 Oct 2023</span>
          </div>
          <a href="/tarea-detalle-light" class="text-[11px] font-semibold text-[#2e75b8] hover:underline flex items-center gap-1 group">
            Ver detalle <span class="material-symbols-outlined text-[14px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
          </a>
        </div>
      </div>

      <!-- Task Card 2 — Medium / Pending -->
      <div class="p-3 bg-white border border-slate-200 rounded-lg shadow-sm hover:border-[#2e75b8]/50 transition-colors">
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-[13px] font-semibold text-slate-800 leading-tight">Refactorizar componentes UI</h3>
          <span class="flex h-2 w-2 rounded-full bg-yellow-500 mt-1 shrink-0"></span>
        </div>
        <div class="text-[10px] text-slate-400 mb-3 flex items-center gap-1">
          <span class="material-symbols-outlined text-[14px]">folder</span>
          <span>Design-System</span>
        </div>
        <div class="flex flex-wrap gap-1.5 mb-3">
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-yellow-100 text-yellow-700 uppercase tracking-wider">Medium</span>
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-blue-100 text-blue-700 uppercase tracking-wider">Pending</span>
        </div>
        <div class="flex items-center justify-between mt-3">
          <div class="flex items-center gap-1 text-[10px] text-slate-400">
            <span class="material-symbols-outlined text-[14px]">calendar_today</span>
            <span>28 Oct 2023</span>
          </div>
          <button class="text-[11px] font-semibold text-[#2e75b8] hover:underline flex items-center gap-1">
            Ver detalle <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
          </button>
        </div>
      </div>

      <!-- Task Card 3 — Low / Done -->
      <div class="p-3 bg-white border border-slate-200 rounded-lg shadow-sm opacity-70 hover:opacity-100 transition-all">
        <div class="flex justify-between items-start mb-2">
          <h3 class="text-[13px] font-semibold text-slate-800 leading-tight line-through opacity-60">Configurar entorno Docker</h3>
          <span class="flex h-2 w-2 rounded-full bg-green-500 mt-1 shrink-0"></span>
        </div>
        <div class="text-[10px] text-slate-400 mb-3 flex items-center gap-1">
          <span class="material-symbols-outlined text-[14px]">folder</span>
          <span>Infrastructure</span>
        </div>
        <div class="flex flex-wrap gap-1.5 mb-3">
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-green-100 text-green-700 uppercase tracking-wider">Low</span>
          <span class="px-2 py-0.5 text-[9px] font-bold rounded bg-emerald-100 text-emerald-700 uppercase tracking-wider">Finished</span>
        </div>
        <div class="flex items-center justify-between mt-3">
          <div class="flex items-center gap-1 text-[10px] text-slate-400">
            <span class="material-symbols-outlined text-[14px]">calendar_today</span>
            <span>20 Oct 2023</span>
          </div>
          <button class="text-[11px] font-semibold text-[#2e75b8] hover:underline flex items-center gap-1">
            Ver detalle <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="p-2 border-t border-slate-200 flex items-center justify-between bg-slate-50 shrink-0">
      <div class="flex items-center gap-1 text-[10px] text-slate-400">
        <span class="material-symbols-outlined text-[12px]">code</span>
        <span>v1.2.4-stable</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="flex h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-[10px] text-slate-400">Connected</span>
      </div>
    </footer>
  </div>
</WebviewLayout>
