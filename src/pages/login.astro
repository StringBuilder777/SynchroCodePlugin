---
import WebviewLayout from '../layouts/WebviewLayout.astro';
---
<WebviewLayout title="SynchroCode — Login" theme="dark">
  <!-- Login Webview (Dark) -->
  <div class="bg-[#09090b] flex-1 flex flex-col p-6">
    <!-- Logo & Title -->
    <div class="flex flex-col items-center mb-8 pt-4">
      <div class="w-10 h-10 bg-[#2e75b8] rounded-lg flex items-center justify-center mb-4 shadow-lg shadow-blue-900/30">
        <span class="material-symbols-outlined text-white text-2xl">sync_alt</span>
      </div>
      <h2 class="text-xl font-semibold text-white">Inicia sesión</h2>
      <p class="text-xs text-zinc-400 mt-1">Sincroniza tu código en tiempo real</p>
    </div>

    <!-- Form -->
    <form class="space-y-4" id="loginForm">
      <div class="space-y-2">
        <label class="text-xs font-medium text-zinc-400 ml-1">Correo electrónico</label>
        <input
          id="email"
          type="email"
          placeholder="tu@empresa.com"
          required
          autocomplete="email"
          class="w-full bg-zinc-900 border border-zinc-700 text-white text-sm rounded-md px-3 py-2.5 focus:outline-none focus:ring-1 focus:ring-[#2e75b8] placeholder:text-zinc-600"
        />
      </div>
      <div class="space-y-2">
        <div class="flex justify-between items-center">
          <label class="text-xs font-medium text-zinc-400 ml-1">Contraseña</label>
          <a href="#" class="text-[11px] text-[#2e75b8] hover:underline font-medium">¿Olvidaste tu clave?</a>
        </div>
        <div class="relative">
          <input
            id="password"
            type="password"
            placeholder="••••••••"
            required
            autocomplete="current-password"
            class="w-full bg-zinc-900 border border-zinc-700 text-white text-sm rounded-md px-3 py-2.5 pr-10 focus:outline-none focus:ring-1 focus:ring-[#2e75b8] placeholder:text-zinc-600"
          />
          <button type="button" id="togglePwd" class="absolute right-3 top-1/2 -translate-y-1/2 text-zinc-500 hover:text-zinc-300">
            <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>
      <div id="loginError" class="hidden text-xs text-red-400 bg-red-900/20 border border-red-800/50 rounded px-3 py-2"></div>
      <button
        id="loginSubmitBtn"
        type="submit"
        class="w-full bg-[#2e75b8] hover:bg-[#2563a8] text-white font-medium py-2.5 rounded-md transition-colors text-sm mt-2 shadow-sm"
      >
        Ingresar
      </button>
    </form>

    <!-- Divider -->
    <div class="relative my-6">
      <div class="absolute inset-0 flex items-center">
        <span class="w-full border-t border-zinc-800"></span>
      </div>
      <div class="relative flex justify-center text-xs uppercase">
        <span class="bg-[#09090b] px-2 text-zinc-500">o continúa con</span>
      </div>
    </div>

    <!-- GitHub -->
    <button id="githubBtn" class="w-full border border-zinc-700 bg-zinc-900 hover:bg-zinc-800 text-white font-medium py-2 rounded-md transition-colors text-sm flex items-center justify-center gap-2">
      <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      Continuar con GitHub
    </button>

    <!-- Sign up -->
    <div class="mt-auto text-center pt-6">
      <p class="text-[11px] text-zinc-500">
        ¿No tienes una cuenta?
        <a href="#" class="text-[#2e75b8] hover:underline font-medium">Regístrate</a>
      </p>
    </div>
  </div>

  <script>
    import { initLogin } from '../scripts/login';

    initLogin({
      formId: 'loginForm',
      emailId: 'email',
      passwordId: 'password',
      togglePasswordButtonId: 'togglePwd',
      eyeIconId: 'eyeIcon',
      errorId: 'loginError',
      submitButtonId: 'loginSubmitBtn',
      githubButtonId: 'githubBtn',
      onLoginSuccess: () => {
        window.location.href = '/tareas';
      },
      openExternal: (url) => {
        window.location.href = url;
      },
    });
  </script>
</WebviewLayout>
