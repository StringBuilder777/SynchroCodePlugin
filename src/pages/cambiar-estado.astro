---
import WebviewLayout from '../layouts/WebviewLayout.astro';
---
<WebviewLayout title="SynchroCode — Cambiar Estado" theme="dark" activeFile="task-detail-renderer.ts">
  <!-- Change Status (Dark) — Overlay -->
  <div class="flex flex-col h-full bg-[#09090b] relative">
    <!-- Background task detail (blurred) -->
    <div class="opacity-40 pointer-events-none select-none px-5 py-4 border-b border-zinc-800">
      <h1 class="text-base font-bold text-zinc-100">Implementar Auth Middleware</h1>
      <p class="text-xs text-zinc-500">SC-1024</p>
      <div class="flex gap-2 mt-3">
        <span class="px-2 py-0.5 bg-red-900/30 text-red-400 text-[10px] font-bold rounded border border-red-800/50">ALTA</span>
        <span class="px-2 py-0.5 bg-purple-900/30 text-purple-400 text-[10px] font-bold rounded border border-purple-800/50">EN PROCESO</span>
      </div>
    </div>

    <!-- Status Change Dropdown Overlay -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[280px] bg-zinc-900 border border-zinc-700 rounded-lg shadow-2xl z-20 overflow-hidden">
      <div class="p-4 border-b border-zinc-800 bg-zinc-950">
        <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">CAMBIAR ESTADO A:</p>
      </div>
      <div class="p-2 space-y-1">
        <!-- Pending -->
        <div class="flex items-center px-4 py-3 hover:bg-zinc-800 cursor-pointer rounded transition-colors">
          <span class="w-3 h-3 bg-zinc-600 rounded-full mr-3"></span>
          <span class="text-sm text-zinc-300">Pendiente</span>
        </div>
        <!-- In Progress (active) -->
        <div class="flex items-center px-4 py-3 bg-purple-900/20 text-purple-300 cursor-pointer rounded border-l-4 border-purple-500">
          <span class="w-3 h-3 bg-purple-500 rounded-full mr-3"></span>
          <span class="text-sm font-semibold">En Proceso</span>
          <span class="material-symbols-outlined text-[16px] ml-auto text-purple-500">check</span>
        </div>
        <!-- Done -->
        <div class="flex items-center px-4 py-3 hover:bg-zinc-800 cursor-pointer rounded transition-colors">
          <span class="w-3 h-3 bg-green-500 rounded-full mr-3"></span>
          <span class="text-sm text-zinc-300">Terminada</span>
        </div>
      </div>
      <button class="w-full p-4 text-xs text-zinc-500 hover:text-zinc-100 text-center border-t border-zinc-800 transition-colors">
        Cancelar
      </button>
    </div>

    <!-- Footer Actions (visible behind overlay) -->
    <div class="absolute bottom-0 left-0 right-0 p-4 space-y-2 border-t border-zinc-800 bg-[#09090b]">
      <button class="w-full py-2 bg-[#2e75b8] text-white rounded text-sm font-medium flex items-center justify-center shadow-sm opacity-30">
        <span class="material-symbols-outlined text-[16px] mr-2">swap_horiz</span>
        Cambiar estado
        <span class="material-symbols-outlined text-[14px] ml-2">expand_more</span>
      </button>
      <button class="w-full py-2 border border-zinc-800 bg-zinc-900 text-zinc-500 rounded text-sm font-medium flex items-center justify-center opacity-30">
        <span class="material-symbols-outlined text-[16px] mr-2">open_in_new</span>
        Ver en Dashboard
      </button>
    </div>
  </div>
</WebviewLayout>
