---
import WebviewLayout from '../layouts/WebviewLayout.astro';
---
<WebviewLayout title="SynchroCode — Cambiar Estado (Claro)" theme="light" activeFile="task-detail-renderer.ts">
  <!-- Change Status (Light) — Overlay -->
  <div class="flex flex-col h-full bg-white relative">
    <!-- Background task detail (blurred) -->
    <div class="opacity-40 pointer-events-none select-none px-5 py-4 border-b border-slate-200">
      <h1 class="text-base font-bold text-zinc-800">Implementar Auth Middleware</h1>
      <p class="text-xs text-slate-400">SC-1024</p>
      <div class="flex gap-2 mt-3">
        <span class="px-2 py-0.5 bg-red-100 text-red-700 text-[10px] font-bold rounded">ALTA</span>
        <span class="px-2 py-0.5 bg-purple-100 text-purple-700 text-[10px] font-bold rounded">EN PROCESO</span>
      </div>
    </div>

    <!-- Status Change Dropdown Overlay -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[280px] bg-white border border-slate-200 rounded-lg shadow-2xl z-20 overflow-hidden">
      <div class="p-4 border-b border-slate-200 bg-slate-50">
        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">CAMBIAR ESTADO A:</p>
      </div>
      <div class="p-2 space-y-1">
        <!-- Pending -->
        <div class="flex items-center px-4 py-3 hover:bg-slate-50 cursor-pointer rounded transition-colors">
          <span class="w-3 h-3 bg-slate-400 rounded-full mr-3"></span>
          <span class="text-sm text-zinc-700">Pendiente</span>
        </div>
        <!-- In Progress (active) -->
        <div class="flex items-center px-4 py-3 bg-purple-50 text-purple-700 cursor-pointer rounded border-l-4 border-purple-500">
          <span class="w-3 h-3 bg-purple-500 rounded-full mr-3"></span>
          <span class="text-sm font-semibold">En Proceso</span>
          <span class="material-symbols-outlined text-[16px] ml-auto text-purple-500">check</span>
        </div>
        <!-- Done -->
        <div class="flex items-center px-4 py-3 hover:bg-slate-50 cursor-pointer rounded transition-colors">
          <span class="w-3 h-3 bg-green-500 rounded-full mr-3"></span>
          <span class="text-sm text-zinc-700">Terminada</span>
        </div>
      </div>
      <button class="w-full p-4 text-xs text-slate-400 hover:text-zinc-700 text-center border-t border-slate-200 transition-colors">
        Cancelar
      </button>
    </div>

    <!-- Footer Actions -->
    <div class="absolute bottom-0 left-0 right-0 p-4 space-y-2 border-t border-slate-200 bg-white">
      <button class="w-full py-2 bg-[#2e75b8] text-white rounded text-sm font-medium flex items-center justify-center shadow-sm opacity-30">
        <span class="material-symbols-outlined text-[16px] mr-2">swap_horiz</span>
        Cambiar estado
        <span class="material-symbols-outlined text-[14px] ml-2">expand_more</span>
      </button>
      <button class="w-full py-2 border border-slate-200 bg-white text-slate-500 rounded text-sm font-medium flex items-center justify-center opacity-30">
        <span class="material-symbols-outlined text-[16px] mr-2">open_in_new</span>
        Ver en Dashboard
      </button>
    </div>
  </div>
</WebviewLayout>
