---
import WebviewLayout from '../layouts/WebviewLayout.astro';
---
<WebviewLayout title="SynchroCode — Colaboración (Claro)" theme="light" activeFile="middleware.ts">
  <!-- Collaboration (Light) — Control Active variant -->
  <div class="flex flex-col h-full bg-white">
    <!-- Header -->
    <div class="p-4 border-b border-slate-200 flex justify-between items-center bg-white shrink-0">
      <a href="/tareas-light" class="flex items-center text-[#2e75b8] text-sm font-medium">
        <span class="material-symbols-outlined text-[16px] mr-1">chevron_left</span>
        Volver
      </a>
      <div class="flex items-center gap-2">
        <div class="flex items-center text-xs text-slate-500">
          <span class="w-2 h-2 bg-green-500 rounded-full mr-1 animate-pulse"></span> Realtime
        </div>
      </div>
    </div>

    <!-- Navigation Tabs -->
    <nav class="flex border-b border-slate-200 bg-white text-xs font-semibold shrink-0">
      <button class="flex-1 text-center py-2.5 text-slate-400 cursor-pointer">Tareas</button>
      <button class="flex-1 text-center py-2.5 text-slate-400 cursor-pointer">Chat</button>
      <button class="flex-1 text-center py-2.5 text-[#2e75b8] border-b-2 border-[#2e75b8] cursor-pointer">Colaborar</button>
    </nav>

    <!-- Role Toggle -->
    <div class="flex bg-white/50 text-[10px] font-bold p-1 border-b border-slate-200 shrink-0">
      <div class="flex-1 flex items-center justify-center py-1 bg-white text-zinc-900 rounded shadow-sm border border-slate-200">
        <span class="material-symbols-outlined text-[12px] mr-1">lock</span>
        Editor A (Lock)
      </div>
      <div class="flex-1 flex items-center justify-center py-1 text-slate-400">
        <span class="material-symbols-outlined text-[12px] mr-1">visibility</span>
        Observador B
      </div>
    </div>

    <!-- Scrollable Content -->
    <div class="flex-1 overflow-y-auto custom-scrollbar p-4 space-y-5">
      <!-- You have control -->
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <div class="w-10 h-10 rounded-full border-2 border-green-500 flex items-center justify-center bg-green-50 text-green-600">
            <span class="material-symbols-outlined text-[20px]">lock</span>
          </div>
          <div class="ml-3">
            <p class="text-sm font-bold text-zinc-800 leading-tight">Tú tienes el control</p>
            <p class="text-[10px] text-slate-400">Editando · middleware.ts</p>
          </div>
        </div>
        <div class="bg-green-500 text-white text-[9px] font-bold px-2 py-1 rounded">LOCK ACTIVO</div>
      </div>

      <!-- Participants -->
      <div>
        <p class="text-[10px] uppercase font-bold text-slate-400 mb-3 tracking-wider">Participantes</p>
        <div class="space-y-2">
          <div class="flex items-center justify-between p-3 bg-white rounded-lg border border-slate-200 shadow-sm">
            <div class="flex items-center">
              <div class="w-8 h-8 rounded-full bg-[#2e75b8] flex items-center justify-center text-xs font-bold text-white">AR</div>
              <div class="ml-3">
                <p class="text-xs font-bold text-zinc-800">Alex Rivera <span class="text-slate-400 font-normal">(tú)</span></p>
                <p class="text-[10px] text-slate-400">Programador</p>
              </div>
            </div>
            <div class="flex items-center text-[9px] font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded border border-green-200">
              <span class="material-symbols-outlined text-[10px] mr-1">lock</span>
              Editando
            </div>
          </div>
          <div class="flex items-center justify-between p-3 bg-white rounded-lg border border-slate-200 shadow-sm">
            <div class="flex items-center">
              <div class="w-8 h-8 rounded-full bg-teal-600 flex items-center justify-center text-xs font-bold text-white">LG</div>
              <div class="ml-3">
                <p class="text-xs font-bold text-zinc-800">Luisa García</p>
                <div class="flex items-center text-[10px] text-orange-500">
                  <span class="w-1.5 h-1.5 rounded-full bg-orange-500 mr-1"></span>
                  Solicitando control...
                </div>
              </div>
            </div>
            <div class="text-[9px] font-bold text-orange-600 bg-orange-50 px-2 py-0.5 rounded border border-orange-200 uppercase">Pendiente</div>
          </div>
        </div>
      </div>

      <!-- Request Control Card -->
      <div class="bg-white border-2 border-orange-300/60 rounded-xl overflow-hidden p-4 shadow-sm">
        <div class="flex items-start justify-between mb-4">
          <div class="flex items-center">
            <div class="w-10 h-10 rounded-full bg-teal-600 flex items-center justify-center text-sm font-bold text-white mr-3">LG</div>
            <div>
              <p class="text-sm font-bold text-zinc-800">Luisa García solicita el control</p>
              <p class="text-[10px] text-slate-400">Quiere editar <code class="text-zinc-700 bg-zinc-100 px-1 rounded">middleware.ts</code></p>
            </div>
          </div>
          <div class="relative w-10 h-10 flex items-center justify-center">
            <svg class="absolute inset-0 w-full h-full transform -rotate-90" viewBox="0 0 44 44">
              <circle cx="22" cy="22" r="18" fill="transparent" stroke="#f1f5f9" stroke-width="3"></circle>
              <circle cx="22" cy="22" r="18" fill="transparent" stroke="#f97316" stroke-width="3" stroke-dasharray="113" stroke-dashoffset="35"></circle>
            </svg>
            <span class="text-sm font-bold text-orange-500">22</span>
          </div>
        </div>
        <div class="flex gap-2">
          <button class="flex-1 bg-[#2e75b8] hover:bg-[#2563a8] text-white text-xs font-bold py-2 rounded flex items-center justify-center transition-colors">
            <span class="material-symbols-outlined text-[14px] mr-1">check</span>
            Ceder control
          </button>
          <button class="flex-1 border border-slate-200 text-slate-500 hover:bg-slate-50 text-xs font-bold py-2 rounded flex items-center justify-center transition-colors">
            <span class="material-symbols-outlined text-[14px] mr-1">close</span>
            Rechazar
          </button>
        </div>
      </div>
    </div>

    <!-- End Session -->
    <div class="p-4 border-t border-slate-200 shrink-0">
      <button class="w-full py-2.5 border-2 border-red-400/50 text-red-500 rounded-md font-bold text-sm flex items-center justify-center gap-2 hover:bg-red-50 transition-colors">
        <span class="material-symbols-outlined text-[18px]">stop_circle</span>
        Finalizar sesión
      </button>
    </div>
  </div>
</WebviewLayout>
