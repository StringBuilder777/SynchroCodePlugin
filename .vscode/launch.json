{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (F5)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "build-plugin"
    },
    {
      "name": "Astro Dev Server",
      "command": "./node_modules/.bin/astro dev",
      "request": "launch",
      "type": "node-terminal"
    }
  ]
}
