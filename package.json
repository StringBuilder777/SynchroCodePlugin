{
  "name": "synchrocodeplugin",
  "displayName": "SynchroCode",
  "description": "Sincroniza tu código con tu equipo en tiempo real",
  "version": "0.0.1",
  "publisher": "synchrocode",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "collaboration",
    "tasks",
    "sync",
    "team"
  ],
  "icon": "media/icon.svg",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "synchrocode",
          "title": "SynchroCode",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "synchrocode": [
        {
          "type": "webview",
          "id": "synchrocode.sidebar",
          "name": "SynchroCode"
        }
      ]
    },
    "commands": [
      {
        "command": "synchrocode.openScreen",
        "title": "SynchroCode: Abrir pantalla"
      }
    ]
  },
  "scripts": {
    "dev": "astro dev",
    "build:webview": "astro build",
    "build:extension": "tsc -p extension/tsconfig.json",
    "build": "npm run build:webview && npm run build:extension",
    "preview": "astro preview",
    "astro": "astro",
    "vscode:prepublish": "npm run build",
    "package": "npx vsce package --no-dependencies"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@supabase/supabase-js": "^2.104.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "5.16.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.575.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "shadcn": "3.7.0",
    "tw-animate-css": "^1.4.0"
  }
}
